# .ralphrc - Ralph project configuration
# SEO Agency Content Engine

PROJECT_NAME="seomachine"
PROJECT_TYPE="typescript"

CLAUDE_CODE_CMD="claude"

MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=15
CLAUDE_OUTPUT_FORMAT="json"

ALLOWED_TOOLS="Write,Read,Edit,Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(git pull *),Bash(git fetch *),Bash(git checkout *),Bash(git branch *),Bash(git stash *),Bash(git merge *),Bash(git tag *),Bash(npm *),Bash(python3 *)"

SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=24

TASK_SOURCES="local"

CB_NO_PROGRESS_THRESHOLD=3
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70

CLAUDE_AUTO_UPDATE=true

# Protected paths -- Ralph must not modify these.
# Enforced by .githooks/pre-commit (see CONTRIBUTING.md for install).
PROTECTED_PATHS=".ralph/:.ralphrc:.claude/commands/:context/:clients/.template/"
